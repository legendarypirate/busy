# =============================================================================
# BUSY.mn Next.js — copy to `.env` on the server and fill values. Never commit `.env`.
# Rotate any secret that was ever pasted into chat, tickets, or logs.
# =============================================================================

# --- Required: Postgres (production must NOT use localhost unless DB is on that machine)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# --- Public site URL (one line; no duplicate keys). Used for OAuth redirect_uri base and header auth logic.
NEXT_PUBLIC_APP_URL="https://busy.mn"
PLATFORM_SESSION_COOKIE_DOMAIN=".busy.mn"

# --- Platform session cookie Max-Age in days (1–400). Unset / 0 / unlimited → 400.
# PLATFORM_SESSION_MAX_DAYS=400

# --- Google OAuth (Next: /api/auth/google + /api/auth/google/callback)
# Google Cloud Console → Web client → Authorized redirect URIs must include exactly:
#   https://busy.mn/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Optional: parent domain for platform + OAuth helper cookies (omit on localhost).
# Use leading dot only, never a full URL:  .busy.mn

# --- Optional: legacy PHP origin (no trailing slash). Forgot-password / old paths.
# If hostname matches NEXT_PUBLIC_APP_URL, the marketing header uses Next /auth/login and /platform
# so Server Actions receive bni_platform_account_id (PHP-only PHPSESSID is not enough).
# NEXT_PUBLIC_LEGACY_SITE_URL="https://busy.mn"

# --- Optional: media base if uploads are not absolute URLs
# NEXT_PUBLIC_MEDIA_BASE="https://cdn.example.com/uploads"

# --- Admin UI: /admin/login — requires `bni_platform_accounts.role = admin` and password (not Google-only).
# Local: run `npm run db:seed` (non-production) → default admin@localhost.local / AdminLocalDev!9
# Optional overrides:
# LOCAL_ADMIN_EMAIL=you@example.com
# LOCAL_ADMIN_PASSWORD=your-long-random-password

# --- Optional: marketing / PHP front URL (not read by all Next routes; safe to omit if unused)
# FRONTEND_URL="https://busy.mn"

# --- Optional: third-party OAuth callback (e.g. TSaaS); not used by Next /api/auth/google
# GOOGLE_CALLBACK_URL="https://api.example.com/api/auth/google/callback"

# --- QPay (optional)
# QPAY_BASE_URL="https://merchant.qpay.mn"
# QPAY_LOGIN=""
# QPAY_PASSWORD=""
# QPAY_INVOICE_CODE=""
# QPAY_RECEIVER_CODE=""
# QPAY_CALLBACK_URL="https://busy.mn/your-qpay-callback"

# --- Email (optional)
# RESEND_API_KEY=""
# MAIL_FROM_ADDRESS="noreply@busy.mn"

# --- Cloudinary (optional)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# --- OpenAI (optional)
# OPENAI_API_KEY=""
# OPENAI_TRANSLATE_MODEL="gpt-4o-mini"

# --- Other app defaults (optional)
# DEFAULT_EVENT_PRICE_MNT=30000
# ADVANCE_PAYMENT_PERCENT=30
# MEMBER_JOIN_DISCOUNT_PERCENT=20
