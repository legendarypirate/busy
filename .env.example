# PostgreSQL connection (Prisma). Required for pages that use Prisma and for Next.js Google sign-in (DB upsert).
# Example local:
DATABASE_URL="postgresql://postgres:Joker0328@localhost:5432/busybni?schema=public"

# Optional: absolute URL for server-side fetches (usually not needed)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Legacy upload / CDN base (matches PHP media paths). Leave empty if media URLs are already absolute.
# NEXT_PUBLIC_MEDIA_BASE="https://your-cdn.example.com/uploads"

# Optional: PHP site origin (no trailing slash). Forgot-password link; Google falls back here if GOOGLE_* not set on Next.
# NEXT_PUBLIC_LEGACY_SITE_URL="http://localhost/bni"

# Google OAuth (Next.js /api/auth/google + /api/auth/google/callback). Add redirect URI in Google Console:
#   {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional demo cookie for logged-in navbar until Next auth: Set-Cookie: bni_platform_nav_display=Your+Name
