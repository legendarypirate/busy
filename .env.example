# PostgreSQL connection (Prisma). Required for pages that use Prisma and for Next.js Google sign-in (DB upsert).
# Example local:
DATABASE_URL="postgresql://postgres:Joker0328@localhost:5432/busybni?schema=public"

# Optional: absolute URL for server-side fetches (usually not needed)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: share platform cookies between www and apex (leading dot = parent domain). Do not set on localhost.
# PLATFORM_SESSION_COOKIE_DOMAIN=.busy.mn

# Legacy upload / CDN base (matches PHP media paths). Leave empty if media URLs are already absolute.
# NEXT_PUBLIC_MEDIA_BASE="https://your-cdn.example.com/uploads"

# Optional: PHP site origin (no trailing slash). Forgot-password link.
# If GOOGLE_* are NOT set on this Next app, "Google" login uses this legacy URL — that signs you into PHP only,
# not into Next.js (no bni_platform_account_id cookie here). For /platform/* use Next Google or email login on this host.
# When LEGACY and NEXT_PUBLIC_APP_URL share the same hostname (e.g. both busy.mn), the site header uses Next
# /auth/login and /platform so Google/email set platform cookies; PHP-only PHPSESSID does not authorize Server Actions.
# NEXT_PUBLIC_LEGACY_SITE_URL="http://localhost/bni"

# Google OAuth (Next.js /api/auth/google + /api/auth/google/callback). Add redirect URI in Google Console:
#   {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional demo cookie for logged-in navbar until Next auth: Set-Cookie: bni_platform_nav_display=Your+Name
